# ─── Root .env.example ──────────────────────────────────────────────────────
# Copy to .env and fill in values for local dev.
# Per-app envs live in apps/api/.env and apps/web/.env (see their .env.example).

# Docker infra (infra/docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=skep_forum_dev
POSTGRES_PORT=5432
REDIS_PORT=6379

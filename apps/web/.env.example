# ─── apps/web/.env.example ─────────────────────────────────────────────────
# Copy to apps/web/.env.local for local dev.

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Mock session — dev only. Real Keycloak/NextAuth swap is deferred.
# This JWT is created client-side via use-mock-session.ts; the secret must
# match apps/api/.env SKEP_JWT_SECRET.
NEXT_PUBLIC_MOCK_JWT_SECRET=dev-only-shared-secret-rotate-in-prod
NEXT_PUBLIC_MOCK_COMMUNITY_CODE=COM96179941
NEXT_PUBLIC_MOCK_PLATFORM_USER_ID=USR61220651
NEXT_PUBLIC_MOCK_ROLE=OWNER

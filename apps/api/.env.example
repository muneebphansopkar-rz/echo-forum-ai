# ─── apps/api/.env.example ─────────────────────────────────────────────────
# Copy to apps/api/.env for local dev.

NODE_ENV=development
API_PORT=3001
API_PREFIX=/api/v1

# Postgres — schema-per-community tenancy
DATABASE_URL=postgres://postgres:root@localhost:5432/skep_forum_dev
DATABASE_SSL=false

# Redis — domain event bus + queue
REDIS_URL=redis://localhost:6379

# Mock JWT (dev only — real Keycloak/SKEP integration deferred)
# Real prod key injected by the SKEP platform; this is the shared dev secret.
SKEP_JWT_SECRET=dev-only-shared-secret-rotate-in-prod
JWT_AUDIENCE=skep-forum
JWT_ISSUER=skep-api

# Rate limits (requests per window)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# CORS — frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:3000
